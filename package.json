{
  "name": "sgs-web-script-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Engineering workspace for SGS Framework, userscript and plugins.",
  "scripts": {
    "build": "node build/build.mjs",
    "publish:check": "node build/publish.mjs --dry-run",
